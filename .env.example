PORT=7080
ISSUER=http://localhost:7080
# Comma-separated. Leading @ is allowed but not required.
ALLOWED_EMAIL_DOMAINS=smartatomic.singles

CLIENT_ID=kiro
CLIENT_SECRET=change-this-client-secret
REDIRECT_URIS=http://localhost:3000/callback
POST_LOGOUT_REDIRECT_URIS=

# Use two or more long random values in production.
COOKIE_KEYS=change-this-cookie-key-1,change-this-cookie-key-2

# Persistent data files. Keep this directory when redeploying.
DATA_DIR=./data
JWKS_PATH=./data/jwks.json
